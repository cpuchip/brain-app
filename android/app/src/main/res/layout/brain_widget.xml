<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧠 Brain"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voice capture"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#BB86FC" />
    </LinearLayout>

    <!-- Entry rows -->
    <LinearLayout
        android:id="@+id/entry_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/entry_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_0_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/entry_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/entry_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_1_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/entry_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/entry_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_2_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/entry_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/entry_3_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_3_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="12dp"
        android:text="Nothing due — you're on top of it ✨"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:visibility="visible" />
</LinearLayout>
