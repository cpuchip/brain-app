<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧠 Brain"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"
            android:src="@android:drawable/stat_notify_sync"
            android:tint="#9E9E9E" />

        <ImageButton
            android:id="@+id/btn_add"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="New entry"
            android:src="@android:drawable/ic_input_add"
            android:tint="#BB86FC" />

        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voice capture"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#BB86FC" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="All clear ✨"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Entry 0 -->
    <LinearLayout
        android:id="@+id/entry_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/entry_0_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mark done"
            android:src="@drawable/ic_check_circle_outline" />

        <TextView
            android:id="@+id/entry_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_0_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Entry 1 -->
    <LinearLayout
        android:id="@+id/entry_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/entry_1_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mark done"
            android:src="@drawable/ic_check_circle_outline" />

        <TextView
            android:id="@+id/entry_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_1_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Entry 2 -->
    <LinearLayout
        android:id="@+id/entry_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/entry_2_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mark done"
            android:src="@drawable/ic_check_circle_outline" />

        <TextView
            android:id="@+id/entry_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_2_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Entry 3 -->
    <LinearLayout
        android:id="@+id/entry_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/entry_3_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="6dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mark done"
            android:src="@drawable/ic_check_circle_outline" />

        <TextView
            android:id="@+id/entry_3_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#E0E0E0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/entry_3_due"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
