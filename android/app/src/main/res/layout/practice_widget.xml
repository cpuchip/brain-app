<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header row: category filter + progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <!-- Category button (tappable to cycle filter) -->
        <TextView
            android:id="@+id/practice_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableEnd="@android:drawable/arrow_down_float"
            android:drawableTint="#9E9E9E"
            android:text="All Practices"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Progress (e.g. "3/5") -->
        <TextView
            android:id="@+id/practice_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:textColor="#BB86FC"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/practice_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No practices today"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Scrollable practice list -->
    <ListView
        android:id="@+id/practice_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />
</LinearLayout>
