<?xml version="1.0" encoding="utf-8"?>
<!-- 2x1 ultra-compact layout: all TextViews to avoid ImageButton min-height issues -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_mini"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <!-- Brain icon — launches main app -->
    <TextView
        android:id="@+id/btn_brain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠"
        android:textSize="16sp"
        android:clickable="true"
        android:focusable="true" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

    <!-- + button (text mode quick-add) -->
    <TextView
        android:id="@+id/btn_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="➕"
        android:textSize="18sp"
        android:clickable="true"
        android:focusable="true"
        android:paddingEnd="10dp" />

    <!-- Mic button (voice mode quick-add) -->
    <TextView
        android:id="@+id/btn_mic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎙️"
        android:textSize="18sp"
        android:clickable="true"
        android:focusable="true" />
</LinearLayout>
